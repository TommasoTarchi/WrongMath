PROJECT_NAME           = "WrongMath"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "A simple wrong math library"
OUTPUT_DIRECTORY       = "@CMAKE_CURRENT_BINARY_DIR@/docs"
INPUT                  = "@CMAKE_SOURCE_DIR@/include" "@CMAKE_SOURCE_DIR@/README.md"
RECURSIVE              = YES
GENERATE_LATEX         = NO
USE_MDFILE_AS_MAINPAGE = "@CMAKE_SOURCE_DIR@/README.md"
EXAMPLE_PATH           = "@CMAKE_SOURCE_DIR@/examples"

OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_OUTPUT_FOR_CPP = YES

SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION     = YES
REFERENCES_LINK_SOURCE  = YES
SOURCE_TOOLTIPS        = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = AUTO
HTML_DYNAMIC_MENUS     = YES
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 250

HAVE_DOT                = YES
DOT_IMAGE_FORMAT       = svg
DOT_PATH               = ""
UML_LOOK               = YES
CLASS_DIAGRAMS        = YES
HAVE_GRAPH            = YES
CALL_GRAPH            = YES
CALLER_GRAPH          = YES
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH       = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_PACKAGE        = YES
EXTRACT_STATIC         = YES

SHOW_USED_FILES        = YES
SHOW_FILES             = YES

GENERATE_TIMESTAMP     = YES
